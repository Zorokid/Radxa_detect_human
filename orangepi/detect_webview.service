[Unit]
Description=detect_human webview host (Orange Pi 5 Max)
After=network.target

[Service]
Type=simple
User=orangepi
# Set this to your Radxa detector's LAN IP (host running detect_human on :8092).
Environment=RADXA_URL=http://192.168.1.10:8092
WorkingDirectory=/home/orangepi/Radxa_detect_human/orangepi
ExecStart=/usr/bin/python3 -u /home/orangepi/Radxa_detect_human/orangepi/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
